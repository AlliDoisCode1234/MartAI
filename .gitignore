# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
temp_md/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files - CRITICAL: Never commit these
.env
.env*.local
.env.local
.env.development
.env.production
.env.staging
*.env

# API keys and secrets
*_API_KEY*
*_SECRET*
*_TOKEN*
*.key
*.secret

# Certificates and private keys
*.pem
*.p12
*.pfx
*.cer
*.crt
*.der
*.key
id_rsa*
*.pub

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# private legal documents
docs/legal/private/

# internal knowledge (client data, intelligence)
docs/.internal/

# LDDs and design docs (kept locally)
docs/

# Temp logs / ad-hoc scripts
*_tmp.txt
*_tmp.log

# Test outputs and debugging artifacts
test-output*.txt
test-out-*.txt
test-clean*.txt
test-verbose*.txt
test-tail*.txt
test-tmp.*
vitest-results.json

# One-off fix/debug scripts (ad-hoc codemods)
fix-*.js
tmp_fix.js
parse-error.js
*-wrapper-fix.js

# Build and error logs
build_output.txt
ts_errors.*
tsc-*.txt
